# HexaStock — Local Environment Variables
#
# Copy this file to .env and replace the placeholders with your real keys.
# The .env file is git-ignored and will never be committed.
#
#   cp .env.example .env
#
# Then either `source .env` before running, or configure the variables
# in your IDE run configuration.
#
# Free-tier keys:
#   Finnhub    → https://finnhub.io/
#   Alpha Vantage → https://www.alphavantage.co/support/#api-key

export FINNHUB_API_KEY=your_finnhub_key_here
export ALPHA_VANTAGE_API_KEY=your_alphavantage_key_here
