@startuml hexastock-hexagonal-architecture
!theme plain
left to right direction

skinparam {
  backgroundColor #FEFEFE
  defaultFontSize 12
  packageStyle rectangle
  componentStyle rectangle
  ArrowColor #555555
}

skinparam package {
  BackgroundColor<<core>> #E8F4FD
  BackgroundColor<<domain>> #D4EDDA
  BackgroundColor<<driving>> #FFF3CD
  BackgroundColor<<persist>> #F8D7DA
  BackgroundColor<<market>> #F8D7DA
  BorderColor #888888
}

title HexaStock  -  Hexagonal Architecture (Sell Stock Use Case)

' ====================================================
' LEFT: DRIVING (PRIMARY) ADAPTER
' ====================================================
package "Driving Adapter\n(adapters-inbound-rest)" <<driving>> {
  [PortfolioRestController] as ctrl
}

' ====================================================
' CENTER: APPLICATION CORE
' ====================================================
package "Application Core" <<core>> {

  () "PortfolioStockOperationsUseCase\n<<inbound port>>" as inPort

  [PortfolioStockOperationsService\n<<application service>>] as svc

  package "Domain Model (domain/)" <<domain>> {
    [Portfolio <<aggregate root>>] as portfolio
    [Holding <<entity>>] as holding
    [Lot <<entity>>] as lot
    [SellResult <<value object>>] as sellResult

    portfolio --> holding : sell()
    holding --> lot : FIFO reduce()
    holding --> sellResult : returns
  }

  () "PortfolioPort\n<<outbound port>>" as portPort
  () "StockPriceProviderPort\n<<outbound port>>" as pricePort
  () "TransactionPort\n<<outbound port>>" as txPort

  portPort -[hidden]down- pricePort
  pricePort -[hidden]down- txPort
}

' ====================================================
' RIGHT: DRIVEN (SECONDARY) ADAPTERS
' ====================================================
package "Persistence Adapters\n(persistence-jpa)" <<persist>> {
  [PortfolioJpaAdapter] as jpaAdapter
  [TransactionJpaAdapter] as txJpaAdapter
}

package "Market Adapters\n(outbound-market)" <<market>> {
  [FinnhubStockPriceAdapter] as finnhub
  [AlphaVantageStockPriceAdapter] as alpha
}

database "MySQL" as db
cloud "Stock Price\nAPIs" as apis

' ====================================================
' WIRING
' ====================================================

' Driving side
ctrl --> inPort : calls
inPort <|.. svc : implements

' Service to domain
svc --> portfolio : delegates to

' Service to outbound ports
svc --> portPort : uses
svc --> pricePort : uses
svc --> txPort : uses

' Port implementations
portPort <|.. jpaAdapter : implements
txPort <|.. txJpaAdapter : implements
pricePort <|.. finnhub : implements
pricePort <|.. alpha : implements

' External systems
jpaAdapter --> db
txJpaAdapter --> db
finnhub --> apis
alpha --> apis

' ====================================================
' LEGEND
' ====================================================
legend bottom left
  |= Color |= Layer |= Maven Module |
  | <#FFF3CD> | Driving Adapters | adapters-inbound-rest |
  | <#E8F4FD> | Application Core | application |
  | <#D4EDDA> | Domain Model | domain |
  | <#F8D7DA> | Driven Adapters | adapters-outbound-* |
  All dependencies point **inward** toward the domain.
  The domain module has zero external dependencies.
  PortfolioRestController: POST /api/portfolios/{id}/sales
  Service: orchestrates (retrieve, delegate, persist), @Transactional
  Value Objects: Money, Price, ShareQuantity, Ticker, PortfolioId
endlegend

@enduml
